{
  "name": "link-leagues-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma centralizada para gerenciamento das ligas acadêmicas da Link — Faculdade de Negócios",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev:web": "pnpm --filter @link-leagues/web dev",
    "dev:api": "pnpm --filter @link-leagues/api dev",
    "build:web": "pnpm --filter @link-leagues/web build",
    "build:api": "pnpm --filter @link-leagues/api build"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.7"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
